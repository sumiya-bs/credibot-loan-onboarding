    {
      "parameters": {
        "operation": "sendAndWait",
        "message": "Please enter the following details for EMI calculation in this format:\n\nLoan Amount, Annual Interest Rate, Tenure in Months\n\nExample:\n500000, 10, 60\n",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chat",
