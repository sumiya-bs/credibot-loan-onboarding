      "id": "a08f24a0-de17-4481-9aa4-d2c4201ac87b",
      "name": "EMI INPUTS",
      "webhookId": "7ae94b6e-717c-4f11-ab53-a4c77be2cc39"
    },
    {
      "parameters": {
        "jsCode": "const input = items[0].json.chatInput;\n\nconst parts = input.split(\",\");\n\nconst loanAmount = parseFloat(parts[0].trim());\nconst annualRate = parseFloat(parts[1].trim());\nconst tenureMonths = parseInt(parts[2].trim(), 10);\n\nconst monthlyRate = annualRate / 12 / 100;\n\nconst emi =\n  (loanAmount * monthlyRate * Math.pow(1 + monthlyRate, tenureMonths)) /\n  (Math.pow(1 + monthlyRate, tenureMonths) - 1);\n\nreturn [\n  {\n    json: {\n      loanAmount,\n      annualRate,\n      tenureMonths,\n      emi: emi.toFixed(2)\n    }\n  }\n];"
      },
