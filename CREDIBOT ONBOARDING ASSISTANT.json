    {
      "parameters": {
        "jsCode": "const result = [];\n\nfor (const item of items) {\n  const binaries = item.binary;\n\n  for (const key of Object.keys(binaries)) {\n\n    const file = binaries[key];\n    const name = (file.fileName || \"\").toLowerCase();\n\n    let type = \"unknown\";\n\n    if (name.includes(\"income\") || name.includes(\"pan\")) {\n      type = \"pan\";\n    }\n\n    if (name.includes(\"aadhaar\") || name.includes(\"uidai\") || name.includes(\"identification\")) {\n      type = \"aadhaar\";\n    }\n\n    result.push({\n      json: { doc_type: type },\n      binary: { data: file }\n    });\n\n  }\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -528,
        -256
      ],
      "id": "ca04045a-9f2e-4ffc-b306-531c189ccefc",
      "name": "split docs"
    },
    {
      "parameters": {
        "jsCode": "const result = [];\n\nfor (const item of items) {\n  const text = item.json.text || '';\n  const upper = text.toUpperCase();\n  const match = upper.match(/[A-Z]{5}[0-9]{4}[A-Z]/);\n\n  if (match) {\n    result.push({\n      json: {\n        pan_number: match[0],\n        pan_text: text\n      }\n    });\n  }\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
