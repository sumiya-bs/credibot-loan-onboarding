    {
      "parameters": {
        "jsCode": "const result = [];\n\nfor (const item of items) {\n  const raw = item.json.text || '';\n\n  // Match Aadhaar formats\n  let match = raw.match(/\\b\\d{4}\\s\\d{4}\\s\\d{4}\\b/);\n  if (!match) {\n    match = raw.match(/\\b\\d{12}\\b/);\n  }\n\n  if (match) {\n    const aadhaar = match[0].replace(/\\D/g, '');\n\n    result.push({\n      json: {\n        aadhaar_number: aadhaar,\n        aadhaar_text: raw\n      }\n    });\n  }\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        -64
      ],
      "id": "2b0c724c-a1ab-45c3-96a5-076265d21712",
      "name": "filter aadhar"
